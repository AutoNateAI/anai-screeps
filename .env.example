# Root env file used by local tools.
# Copy any needed keys into .env. Never commit real values.

# Required by screepers/screeps-launcher before the local server will start.
# Get one from https://steamcommunity.com/dev/apikey
STEAM_KEY=

# Existing Airtable learning/workforce data keys live in the real .env only.
AIRTABLE_API_KEY=
AIRTABLE_BASE_ID_MARKET_MATRIX=
AIRTABLE_BASE_ID_GAMELAB=

